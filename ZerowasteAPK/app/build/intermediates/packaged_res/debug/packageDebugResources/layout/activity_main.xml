<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/social_background"
    tools:context=".MainActivity">

    <!-- Card Profil -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16.dp"
        app:cardBackgroundColor="@color/social_primary"
        app:cardCornerRadius="12.dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16.dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWelcomeName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Halo, Budi!"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Poin Kamu: 150 pts"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivProfile"
                android:layout_width="40.dp"
                android:layout_height="40.dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_person"
                app:tint="@color/white" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- Tombol Navigasi -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16.dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/cardProfile">

        <Button
            android:id="@+id/btnNavUpload"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4.dp"
            android:layout_weight="1"
            android:backgroundTint="@color/social_accent"
            android:text="Upload Donasi" />

        <Button
            android:id="@+id/btnNavStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4.dp"
            android:layout_weight="1"
            android:text="Cek Status" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvLabelAvailable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16.dp"
        android:text="Makanan Tersedia Terdekat"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutButtons" />

    <!-- RecyclerView Daftar Makanan -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMakanan"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8.dp"
        android:paddingHorizontal="12.dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLabelAvailable" />

</androidx.constraintlayout.widget.ConstraintLayout>
